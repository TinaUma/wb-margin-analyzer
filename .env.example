# Copy this file to .env and fill in the values
# Generate SECRET_KEY with: openssl rand -hex 32

# Required — used by backend locally (Docker Compose overrides this automatically)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wb_margin

# Required — JWT signing key
SECRET_KEY=your-secret-key-here

# Optional — leave empty to start without AI features (AI endpoints return 503)
ANTHROPIC_API_KEY=sk-ant-...

# CORS origins — adjust if frontend runs on a different port
CORS_ORIGINS=["http://localhost:5173"]
